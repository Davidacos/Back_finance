# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=finance_db
DB_CONNECTION_LIMIT=10

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
